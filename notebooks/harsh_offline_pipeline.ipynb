    "# Stage 1: Optimized Environment Setup (using uv for 10x speedup)\n",
    "import subprocess, sys, traceback, os, time\n",
    "import IPython\n",
    "\n",
    "t_start = time.time()\n",
    "\n",
    "def custom_exc(shell, etype, evalue, tb, tb_offset=None):\n",
    "    print(\"\\n\" + \"=\"*60)\n",
    "    print(\"!!! AN ERROR OCCURRED !!!\")\n",
    "    print(\"=\"*60)\n",
    "    traceback.print_exception(etype, evalue, tb)\n",
    "    print(\"=\"*60)\n",
    "\n",
    "_ipython = IPython.get_ipython()\n",
    "if _ipython:\n",
    "    _ipython.set_custom_exc((Exception,), custom_exc)\n",
    "    _ipython.magic(\"xmode Verbose\")\n",
    "\n",
    "REPO_DIR = '/content/vibescent'\n",
    "GITHUB_REPO = 'https://github.com/GavinGongTech/VibeScent.git'\n",
    "\n",
    "print(\"Step 1: Repo sync...\")\n",
    "if os.path.exists(os.path.join(REPO_DIR, '.git')):\n",
    "    subprocess.run(['git', '-C', REPO_DIR, 'pull', 'origin', 'main'], capture_output=True)\n",
    "else:\n",
    "    subprocess.run(['git', 'clone', '--depth=1', GITHUB_REPO, REPO_DIR], check=True)\n",
    "os.chdir(REPO_DIR)\n",
    "\n",
    "print(\"Step 2: Install uv (fast package manager)...\")\n",
    "subprocess.run([sys.executable, '-m', 'pip', 'install', '-q', 'uv'], check=True)\n",
    "\n",
    "print(\"Step 3: Mounting Google Drive...\")\n",
    "try:\n",
    "    from google.colab import drive\n",
    "    drive.mount('/content/drive', force_remount=True)\n",
    "    os.environ['UV_CACHE_DIR'] = '/content/drive/MyDrive/uv_cache'\n",
    "    os.makedirs(os.environ['UV_CACHE_DIR'], exist_ok=True)\n",
    "except Exception as e:\n",
    "    print(f\"[WARN] Drive mount skipped: {e}\")\n",
    "\n",
    "print(\"Step 4: Installing dependencies with uv (parallelized)...\")\n",
    "_required_pkgs = [\n",
    "    'google-genai', 'pandas', 'numpy', 'accelerate', 'qwen-vl-utils>=0.0.14',\n",
    "    'json-repair', 'tqdm', 'outlines>=1.2.0', 'transformers>=4.57.0,<5.0',\n",
    "    'bitsandbytes', 'hf_transfer', 'flash-attn --no-build-isolation'\n",
    "]\n",
    "\n",
    "# Batch install with uv\n",
    "subprocess.run(['uv', 'pip', 'install', '--system', '-q'] + _required_pkgs, check=True)\n",
    "\n",
    "print(\"Step 5: Installing vibescent project (editable mode)...\")\n",
    "subprocess.run(['uv', 'pip', 'install', '--system', '-q', '--no-deps', '-e', '.'], check=True)\n",
    "\n",
    "try:\n",
    "    import torch\n",
    "    _gpu = torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'CPU'\n",
    "    print(f\"\\n[OK] Setup complete in {time.time()-t_start:.1f}s | Torch: {torch.__version__} | GPU: {_gpu}\")\n",
    "except Exception as e:\n",
    "    print(f\"[WARN] Check failed: {e}\")\n",
    "\n",
    "print('\\nRestart runtime now, then continue from Stage 2.')"
   ]
