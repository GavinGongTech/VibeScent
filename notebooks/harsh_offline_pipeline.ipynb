    "# Stage 5: Optimized Corpus Re-embedding (Qwen3-VL-Embedding-8B)\n",
    "import sys, os, time, torch, gc, json, glob\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from pathlib import Path\n",
    "from tqdm.auto import tqdm\n",
    "\n",
    "# Paths\n",
    "REPO_DIR       = globals().get('REPO_DIR', '/content/vibescent')\n",
    "DRIVE_BASE     = globals().get('DRIVE_BASE', '/content/drive/MyDrive/vibescent_offline')\n",
    "ENRICHED_CSV   = os.path.join(DRIVE_BASE, 'vibescent_enriched_full.csv')\n",
    "EMBEDDINGS_DIR = os.path.join(DRIVE_BASE, 'qwen3vl_corpus')\n",
    "CKPT_DIR       = os.path.join(EMBEDDINGS_DIR, 'ckpts')\n",
    "os.makedirs(CKPT_DIR, exist_ok=True)\n",
    "\n",
    "sys.path.insert(0, os.path.join(REPO_DIR, 'src'))\n",
    "from vibescents.embeddings import Qwen3VLMultimodalEmbedder\n",
    "from vibescents.settings import Settings\n",
    "\n",
    "# 1. Load Data\n",
    "df_embed = pd.read_csv(ENRICHED_CSV)\n",
    "if 'retrieval_text' not in df_embed.columns:\n",
    "    from vibescents.enrich import build_retrieval_text\n",
    "    df_embed = build_retrieval_text(df_embed)\n",
    "texts = df_embed['retrieval_text'].fillna(df_embed.get('name', '')).tolist()\n",
    "\n",
    "# 2. Setup Embedder\n",
    "gc.collect(); torch.cuda.empty_cache()\n",
    "torch.backends.cuda.matmul.allow_tf32 = True\n",
    "torch.backends.cudnn.allow_tf32 = True\n",
    "\n",
    "Qwen3VLMultimodalEmbedder._BATCH_SIZE = 128 # Max throughput for A100\n",
    "embedder = Qwen3VLMultimodalEmbedder(settings=Settings(), load_in_8bit=False)\n",
    "\n",
    "# 3. Fast Resume\n",
    "def get_ckpts(): return sorted(glob.glob(os.path.join(CKPT_DIR, '*.npy')))\n",
    "done_count = sum(np.load(f).shape[0] for f in get_ckpts())\n",
    "print(f\"Resuming from {done_count} / {len(texts)}\")\n",
    "\n",
    "# 4. Run Embedding\n",
    "t0 = time.perf_counter()\n",
    "CHUNK_SIZE = 128 * 50 # Save every 6400 rows\n",
    "\n",
    "remaining_texts = texts[done_count:]\n",
    "if remaining_texts:\n",
    "    for i in range(0, len(remaining_texts), CHUNK_SIZE):\n",
    "        chunk = remaining_texts[i : i + CHUNK_SIZE]\n",
    "        chunk_emb = embedder.embed_multimodal_documents(chunk)\n",
    "        \n",
    "        ckpt_path = os.path.join(CKPT_DIR, f\"part_{len(get_ckpts()):04d}.npy\")\n",
    "        np.save(ckpt_path, chunk_emb)\n",
    "        print(f\" Saved {ckpt_path} | Total: {done_count + i + len(chunk)}\")\n",
    "\n",
    "# 5. Consolidate & Verify\n",
    "print(\"Consolidating shards...\")\n",
    "embeddings = np.vstack([np.load(f) for f in get_ckpts()])\n",
    "np.save(os.path.join(EMBEDDINGS_DIR, 'embeddings.npy'), embeddings)\n",
    "\n",
    "manifest = {\n",
    "    'model': 'Qwen/Qwen3-VL-Embedding-8B',\n",
    "    'n_rows': len(embeddings), 'dim': embeddings.shape[1],\n",
    "    'l2_normalized': True\n",
    "}\n",
    "with open(os.path.join(EMBEDDINGS_DIR, 'manifest.json'), 'w') as f:\n",
    "    json.dump(manifest, f, indent=2)\n",
    "\n",
    "print(f\"Done in {time.perf_counter()-t0:.0f}s | Shape: {embeddings.shape}\")\n",
    "gc.collect(); torch.cuda.empty_cache()\n"
