    "# Stage 4: Optimized LLM Enrichment (Qwen3-8B + vLLM + Fast Checkpointing)\n",
    "import sys, os, json, traceback, shutil, time\n",
    "import torch, gc\n",
    "import pandas as pd\n",
    "from tqdm.auto import tqdm\n",
    "\n",
    "# Paths\n",
    "REPO_DIR = globals().get('REPO_DIR', '/content/vibescent')\n",
    "DRIVE_BASE = globals().get('DRIVE_BASE', '/content/drive/MyDrive/vibescent_offline')\n",
    "INPUT_CSV = os.path.join(REPO_DIR, 'data', 'vibescent_enriched.csv')\n",
    "ENRICHED_CSV = os.path.join(DRIVE_BASE, 'vibescent_enriched_full.csv')\n",
    "JSONL_CHECKPOINT = os.path.join(DRIVE_BASE, 'enrichment_cache.jsonl')\n",
    "FAILURES_LOG = os.path.join(DRIVE_BASE, 'enrichment_failures.jsonl')\n",
    "\n",
    "sys.path.insert(0, os.path.join(REPO_DIR, 'src'))\n",
    "from vibescents.enrich import (\n",
    "    VLLMNativeEnrichmentClient,\n",
    "    QwenOutlinesEnrichmentClient,\n",
    "    build_retrieval_text,\n",
    "    ENRICHMENT_COLUMNS,\n",
    "    _build_prompt,\n",
    "    _serialize_value,\n",
    ")\n",
    "\n",
    "# 1. Load Data\n",
    "df_work = pd.read_csv(INPUT_CSV)\n",
    "if 'fragrance_id' not in df_work.columns:\n",
    "    df_work.insert(0, 'fragrance_id', df_work.index.astype(str))\n",
    "\n",
    "# 2. Fast Resume (Merge JSONL cache)\n",
    "if os.path.exists(JSONL_CHECKPOINT):\n",
    "    print(f\"Loading fast cache from {JSONL_CHECKPOINT}...\")\n",
    "    with open(JSONL_CHECKPOINT, 'r') as f:\n",
    "        for line in f:\n",
    "            item = json.loads(line)\n",
    "            idx = int(item['idx'])\n",
    "            for col in ENRICHMENT_COLUMNS:\n",
    "                if col in item:\n",
    "                    df_work.at[idx, col] = item[col]\n",
    "\n",
    "# 3. Setup Model (ABSOLUTE SOTA 2026: Qwen3.5-35B-Instruct)
# Currently #1 on Berkeley Function Calling Leaderboard for open-weight models.
ENRICHMENT_MODEL = \"Qwen/Qwen3.5-35B-Instruct\"
BATCH_SIZE = 24 # 35B MoE is memory-intensive; 24 is safe on A100 80GB

# Prevent \"CUDA already initialized\" errors
if 'client' in globals():
    print(\"Re-using existing client...\")
else:
    gc.collect(); torch.cuda.empty_cache(); time.sleep(2)
    try:
        # 35B MoE model in bfloat16 is the peak for a single A100 80GB.
        client = VLLMNativeEnrichmentClient(model_name=ENRICHMENT_MODEL)
        print(f\"Backend: vLLM Native | Model: {ENRICHMENT_MODEL}\")
    except Exception as e:
        print(f\"vLLM failed ({e}), using Outlines fallback.\")
        client = QwenOutlinesEnrichmentClient(model_name=ENRICHMENT_MODEL)

    "except Exception as e:\n",
    "    print(f\"vLLM failed ({e}), using Outlines fallback.\")\n",
    "    client = QwenOutlinesEnrichmentClient(model_name=ENRICHMENT_MODEL)\n",
    "\n",
    "# 4. Filter work\n",
    "for col in ENRICHMENT_COLUMNS: \n",
    "    if col not in df_work.columns: df_work[col] = None\n",
    "\n",
    "need_mask = df_work['vibe_sentence'].isna()\n",
    "need_idx = df_work[need_mask].index.tolist()\n",
    "print(f\"Enriching {len(need_idx)} rows (Batch Size: {BATCH_SIZE})\")\n",
    "\n",
    "# 5. Run Enrichment with Append-Only Checkpointing\n",
    "ok, fail = 0, 0\n",
    "t0 = time.time()\n",
    "\n",
    "with open(JSONL_CHECKPOINT, 'a') as cache_f, tqdm(total=len(need_idx)) as pbar:\n",
    "    for i in range(0, len(need_idx), BATCH_SIZE):\n",
    "        batch_idx = need_idx[i : i + BATCH_SIZE]\n",
    "        prompts = [_build_prompt(df_work.loc[idx]) for idx in batch_idx]\n",
    "        \n",
    "        try:\n",
    "            records = client.generate_batch(prompts)\n",
    "            for idx, record in zip(batch_idx, records):\n",
    "                if record:\n",
    "                    row_data = {'idx': int(idx)}\n",
    "                    for col in ENRICHMENT_COLUMNS:\n",
    "                        val = _serialize_value(getattr(record, col))\n",
    "                        df_work.at[idx, col] = val\n",
    "                        row_data[col] = val\n",
    "                    cache_f.write(json.dumps(row_data) + '\\n')\n",
    "                    ok += 1\n",
    "                else:\n",
    "                    fail += 1\n",
    "            cache_f.flush() # Ensure Drive sync\n",
    "        except Exception as e:\n",
    "            print(f\"Batch Error: {e}\")\n",
    "            fail += len(batch_idx)\n",
    "            \n",
    "        pbar.update(len(batch_idx))\n",
    "        pbar.set_postfix(ok=ok, fail=fail, rows_sec=f\"{ok/(time.time()-t0):.1f}\")\n",
    "\n",
    "# 6. Final Save\n",
    "df_work = build_retrieval_text(df_work)\n",
    "df_work.to_csv(ENRICHED_CSV, index=False)\n",
    "print(f\"\\nComplete! Saved to {ENRICHED_CSV}\")\n",
    "gc.collect(); torch.cuda.empty_cache()\n"
   ]
  },
